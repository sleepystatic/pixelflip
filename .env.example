NEXT_PUBLIC_DASHBOARD_SIGNUP_URL=https://app.yoursite.com/sign-up

# Contact form → Mailgun (API key from Mailgun dashboard; keep secret — server only)
MAILGUN_API_KEY=key-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
